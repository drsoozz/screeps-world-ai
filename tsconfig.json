{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "lib": ["es2018", "DOM"],
    "target": "es2018",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src/",
    "baseUrl": "src/",
    "sourceMap": true,
    "strict": true,
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "types": ["screeps", "node"]
  },
  "exclude": ["node_modules"]
}
